# Clerk authentication — create a project at https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY

# Neon Postgres — copy this from the Neon dashboard / Vercel integration
DATABASE_URL=postgres://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# Comma-separated list of email addresses that get admin access
ADMIN_EMAILS=your@email.com
